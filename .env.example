# 阿里云认证配置
# 请替换为您的实际阿里云AccessKey ID和AccessKey Secret
ACCESS_KEY_ID=your_access_key_id_here
ACCESS_KEY_SECRET=your_access_key_secret_here

# FastMCP日志级别
FASTMCP_LOG_LEVEL=INFO

# 缓存配置
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# 开发环境配置
DEVELOPMENT=true

# ============================================================
# OAuth 2.1 Authentication (Optional)
# Enable OAuth for HTTP/SSE transport security.
# See SECURITY.md for detailed configuration guidance.
# ============================================================
# ENABLE_OAUTH=false
# OAUTH_JWKS_URI=https://your-auth-provider.com/.well-known/jwks.json
# OAUTH_ISSUER=https://your-auth-provider.com
# OAUTH_AUDIENCE=alibabacloud-ack-mcp-server
# OAUTH_BASE_URL=https://your-mcp-server.com
# OAUTH_REQUIRED_SCOPES=ack:read