{
  "name": "ack-mcp-server",
  "version": "1.0.0",
  "mcpServers": {
    "ack-mcp-server": {
      "command": "uv",
      "args": ["run", "main_server.py", "--transport=stdio", "--allow-write"],
      "cwd": "${extensionPath}/src"
    }
  },
  "settings":[
    {
      "name": "Access Key ID",
      "description": "Your Access Key ID.",
      "envVar": "ACCESS_KEY_ID",
      "sensitive": true
    },
    {
      "name": "Access Key Secret",
      "description": "Your Access Key Secret.",
      "envVar": "ACCESS_KEY_SECRET",
      "sensitive": true
    }
  ]
}
